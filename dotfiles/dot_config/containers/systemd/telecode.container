[Unit]
Description=Telecode Telegram agent (containerized)
After=default.target
# StartLimit* keys belong in [Unit] per systemd.unit(5).
StartLimitBurst=5
StartLimitIntervalSec=60

[Container]
Image=localhost/telecode
ContainerName=telecode
Volume=/home/neg/.telecode:/data:rw
HealthCmd=pgrep -f telecode || exit 1
HealthInterval=30s
HealthRetries=3
HealthTimeout=10s
Notify=healthy

[Service]
Restart=on-failure
RestartSec=5
TimeoutStartSec=60

[Install]
WantedBy=default.target
