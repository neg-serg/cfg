// Niri configuration (KDL)
// See https://github.com/YaLTeR/niri/blob/main/examples/config.kdl for full examples

output "DP-2" {
    mode "3840x2160@240"
    scale 2.0
    position x=0 y=0
    variable-refresh-rate
    // Note: bitdepth not configurable in Niri
}

output "DP-1" {
    off
}

input {
    keyboard {
        xkb {
            layout "us,ru"
        }
        numlock
        repeat_delay 250
        repeat_rate 35
    }
    
    touchpad {
        tap
        natural-scroll
    }
    
    mouse {
        // natural-scroll
    }
}

// Workspace layout
layout {
    gaps 0
    center-focused-column "never"
    
    // Hyprland scrolling features not supported in Niri:
    // - fullscreen_on_one_column
    // - follow_focus
    // - follow_min_visible
    // - direction
    // - focus_fit_method
    // (see Hyprland config for details)
    
    focus-ring {
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }
    
    border {
        width 1
        active-color "#00285981"
        inactive-color "#00000000"
    }
    
    shadow {
        off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    
    default-column-width { proportion 0.5; }
    preset-column-widths {
        proportion 0.5
        proportion 1.0
    }
}

// Keybindings
binds {
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }
    
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }
    Mod+Ctrl+L { move-column-right; }
    
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up   { focus-workspace-up; }
    Mod+U         { focus-workspace-down; }
    Mod+I         { focus-workspace-up; }
    
    Mod+Return { spawn "kitty" "--single-instance"; }
    Mod+D { spawn "vicinae" "toggle"; }
    Mod+Shift+D { spawn "zen-browser"; }
    
    Mod+Q { close-window; }
    Mod+Shift+Q { exit; }
    Mod+Escape { close-window; }
    Mod+Space { toggle-overview; }
}

// Status bar (optional)
// bar { ... }

// Animations
animations {
    enabled true
    spring 400,0.5
}

// Misc
misc {
    focus_on_window_activation true
    border_width 1
    border_color 0xFFFFFF
}
