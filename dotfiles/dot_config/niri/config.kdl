// Niri configuration (KDL)
// See https://github.com/YaLTeR/niri/blob/main/examples/config.kdl for full examples

output "DP-2" {
    mode "3840x2160@240"
    scale 2.0
    position x=0 y=0
    variable-refresh-rate
    // Note: bitdepth not configurable in Niri
}

output "DP-1" {
    off
}

input "type:keyboard" {
    xkb_layout "us"
    xkb_variant ""
    repeat_delay 600
    repeat_rate 25
}

input "type:pointer" {
    accel_profile "flat"
    natural_scroll false
}

input "type:touchpad" {
    tap true
    natural_scroll false
}

// Workspace layout
layout {
    gaps 0
    center-focused-column "never"
    
    // Hyprland scrolling features not supported in Niri:
    // - fullscreen_on_one_column
    // - follow_focus
    // - follow_min_visible
    // - direction
    // - focus_fit_method
    // (see Hyprland config for details)
    
    focus-ring {
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }
    
    border {
        width 1
        active-color "#00285981"
        inactive-color "#00000000"
    }
    
    shadow {
        off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    
    default-column-width { proportion 0.5; }
    preset-column-widths {
        proportion 0.5
        proportion 1.0
    }
}

// Keybindings
bind "Super+Return" action=spawn cmd="kitty"
bind "Super+Q" action=close_window
bind "Super+Shift+Q" action=exit
bind "Super+D" action=spawn cmd="rofi -show drun"
bind "Super+Shift+D" action=spawn cmd="rofi -show run"
bind "Super+Space" action=toggle_overview

// Status bar (optional)
// bar { ... }

// Animations
animations {
    enabled true
    spring 400,0.5
}

// Misc
misc {
    focus_on_window_activation true
    border_width 1
    border_color 0xFFFFFF
}
