{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "model": "cliproxyapi/gpt-5.4-mini",
  "provider": {
    "cliproxyapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CliProxyApi",
      "options": {
        "baseURL": "http://192.168.2.166:8317/v1"
      },
      "models": {
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "gpt-5.2": {
          "name": "GPT 5.2",
          "reasoning": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "minimal": { "reasoningEffort": "minimal" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "xhigh": { "reasoningEffort": "xhigh" }
          }
        },
        "gpt-5.3": {
          "name": "GPT 5.3",
          "reasoning": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "minimal": { "reasoningEffort": "minimal" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "xhigh": { "reasoningEffort": "xhigh" }
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "reasoning": true,
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "minimal": { "reasoningEffort": "minimal" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "xhigh": { "reasoningEffort": "xhigh" }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "reasoning": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "minimal": { "reasoningEffort": "minimal" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "xhigh": { "reasoningEffort": "xhigh" }
          }
        },
        "gpt-5.5": {
          "name": "GPT 5.5",
          "reasoning": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "minimal": { "reasoningEffort": "minimal" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "xhigh": { "reasoningEffort": "xhigh" }
          }
        }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{{ gopass "api/deepseek" }}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "none": { "reasoningEffort": "none" },
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" }
          }
        }
      }
    }
  },
  "mcp": {
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "yt-dlp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@kevinwatt/yt-dlp-mcp@latest"
      ]
    },
    "youtube": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anaisbetts/mcp-youtube"
      ]
    }
  }
}
