[Unit]
Description=MPD AudioScrobbler (Last.fm)
After=mpd.service
Requires=mpd.service

[Service]
Environment=ALL_PROXY=socks5h://127.0.0.1:10808
ExecStart=/bin/mpdas -c %h/.config/mpdasrc
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectSystem=strict
PrivateTmp=yes
PrivateDevices=yes
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes

[Install]
WantedBy=default.target
