#!/usr/bin/env zsh
setopt ERR_EXIT NOUNSET PIPE_FAIL
IFS=$'\n\t'

log() {
  printf 'hypr-shortcuts: %s\n' "$*" >&2
}

vicinae_bin="${VICINAE_BIN:-$(command -v vicinae 2> /dev/null || true)}"
data_file="${HYPR_SHORTCUTS_DATA:-$HOME/.config/hypr/generated/shortcuts.json}"

if [ -z "$vicinae_bin" ]; then
  log "vicinae binary not found in PATH"
  exit 1
fi

if [ ! -f "$data_file" ]; then
  log "shortcuts dataset not found: $data_file"
  exit 1
fi

selection="$({
  jq -r '.[] | select(.mode == "launchable") | .label' "$data_file"
} | "$vicinae_bin" dmenu --placeholder "shortcuts" --section-title "Shortcuts {count}" --navigation-title "Shortcuts")" || exit 0

[ -n "$selection" ] || exit 0

command="$(jq -r --arg label "$selection" '.[] | select(.mode == "launchable" and .label == $label) | .command' "$data_file")"

if [ -z "$command" ] || [ "$command" = "null" ]; then
  log "no command found for selection: $selection"
  exit 1
fi

zsh -lc "$command"
