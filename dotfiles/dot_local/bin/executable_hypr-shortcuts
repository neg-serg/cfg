#!/usr/bin/env zsh
setopt ERR_EXIT NOUNSET PIPE_FAIL
IFS=$'\n\t'

log() {
  printf 'hypr-shortcuts: %s\n' "$*" >&2
}

vicinae_bin="${VICINAE_BIN:-$(command -v vicinae 2> /dev/null || true)}"
data_file="${HYPR_SHORTCUTS_DATA:-$HOME/.config/hypr/generated/shortcuts.json}"

if [ -z "$vicinae_bin" ]; then
  log "vicinae binary not found in PATH"
  exit 1
fi

if [ ! -f "$data_file" ]; then
  log "shortcuts dataset not found: $data_file"
  exit 1
fi

set +e
menu_entries="$(jq -r '.[] | select(.mode == "launchable") | [.id, .label] | @tsv' "$data_file")"
jq_status=$?
set -e

if [ "$jq_status" -ne 0 ]; then
  log "failed to parse launchable shortcuts from $data_file"
  exit "$jq_status"
fi

[ -n "$menu_entries" ] || exit 0

set +e
selection="$(printf '%s' "$menu_entries" | "$vicinae_bin" dmenu --placeholder "shortcuts" --section-title "Shortcuts {count}" --navigation-title "Shortcuts")"
menu_status=$?
set -e

if [ "$menu_status" -ne 0 ]; then
  if [ "$menu_status" -eq 130 ]; then
    exit 0
  fi
  log "shortcut picker failed"
  exit "$menu_status"
fi

[ -n "$selection" ] || exit 0

case "$selection" in
  *$'\t'*) ;;
  *)
    log "invalid shortcut selection: $selection"
    exit 1
    ;;
esac

selection_id="${selection%%$'\t'*}"
[ -n "$selection_id" ] || {
  log "invalid shortcut selection: $selection"
  exit 1
}

command="$(jq -r --arg id "$selection_id" '
  [.[] | select(.mode == "launchable" and .id == $id) | .command] as $commands
  | if ($commands | length) == 1 then
      $commands[0]
    elif ($commands | length) == 0 then
      empty
    else
      error("ambiguous launchable shortcut id: \($id)")
    end
' "$data_file")" || {
  log "failed to resolve shortcut command for id: $selection_id"
  exit 1
}

if [ -z "$command" ] || [ "$command" = "null" ]; then
  log "no command found for shortcut id: $selection_id"
  exit 1
fi

case "$command" in
  *$'\n'*)
    log "shortcut command for $selection_id is not single-line"
    exit 1
    ;;
esac

zsh -lc "$command"
