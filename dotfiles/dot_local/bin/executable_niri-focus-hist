#!/usr/bin/env python3
"""Track Niri window focus history via JSON‑IPC.

Daemon mode (default): subscribes to window‑opened, window‑closed, window‑focused
events via `niri msg subscribe`, maintains an ordered focus history, and writes
the previous window address to a state file.

Switch mode (--switch): reads the state file and focuses the previous window.
"""

from __future__ import annotations

import atexit
import json
import os
import re
import signal
import subprocess
import sys
from collections import deque

# Assumption: Niri window addresses are hex strings prefixed with "0x".
# This regex should be verified against actual `niri msg subscribe` output
# during windowed‑mode testing (Task 9).
ADDR_REGEX = re.compile(r'^0x[0-9a-f]+$', re.IGNORECASE)


def state_path() -> str:
    runtime = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    return f"{runtime}/niri-focus-history"


def ensure_parent_dir(p: str) -> None:
    """Create parent directory if it doesn't exist."""
    parent = os.path.dirname(p)
    if parent:
        os.makedirs(parent, exist_ok=True)


def write_state(path: str, addr: str) -> None:
    """Write window address to state file."""
    try:
        with open(path, "w") as f:
            f.write(addr)
    except OSError as e:
        sys.stderr.write(f"Error writing state file: {e}\n")


def remove_state(path: str) -> None:
    """Remove state file if it exists."""
    try:
        os.remove(path)
    except FileNotFoundError:
        pass
    except OSError as e:
        sys.stderr.write(f"Error removing state file: {e}\n")


def switch() -> int:
    """Read previous window address from state file and focus it."""
    path = state_path()
    try:
        with open(path) as f:
            addr = f.read().strip()
    except FileNotFoundError:
        return 1
    if not addr:
        return 1
    if not ADDR_REGEX.fullmatch(addr):
        sys.stderr.write(f"Invalid window address format: {addr}\n")
        return 1
    try:
        result = subprocess.run(
            ["niri", "msg", "action", "focus-window", f"address={addr}"],
            check=False,
            stdout=subprocess.DEVNULL,
        )
    except (FileNotFoundError, OSError) as e:
        sys.stderr.write(f"Failed to run niri: {e}\n")
        return 1
    if result.returncode != 0:
        return 1
    return 0


def daemon() -> None:
    """Listen to Niri events and track focus history."""
    try:
        proc = subprocess.Popen(
            ["niri", "msg", "subscribe", "--events", "window-opened,window-closed,window-focused"],
            stdout=subprocess.PIPE,
            text=True,
        )
    except (FileNotFoundError, OSError) as e:
        sys.stderr.write(f"Failed to start niri: {e}\n")
        sys.exit(1)
    # Note: This script does not automatically reconnect if `niri msg subscribe` exits.
    # It should be supervised (e.g., by a systemd user service) that restarts it on failure.
    history: deque[str] = deque(maxlen=20)
    path = state_path()
    ensure_parent_dir(path)

    def cleanup() -> None:
        if proc.poll() is None:
            try:
                proc.terminate()
            except ProcessLookupError:
                # Process already terminated between poll() and terminate()
                return
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait()
            except ProcessLookupError:
                # Process already terminated after terminate()
                pass
    atexit.register(cleanup)

    def signal_handler(signum, frame) -> None:
        cleanup()
        sys.exit(0)
    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)

    try:
        while True:
            line = proc.stdout.readline()
            if not line:
                break
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue

            if event.get("type") == "window-focused":
                addr = event.get("window", {}).get("address")
                if not addr:
                    continue
                if not ADDR_REGEX.fullmatch(addr):
                    continue
                # Skip if already the most recent
                if history and history[-1] == addr:
                    continue
                # Move to end (re-insert)
                if addr in history:
                    # Remove existing occurrence while preserving order and maxlen
                    history = deque([a for a in history if a != addr], maxlen=20)
                history.append(addr)
                # Write previous window to state file
                if len(history) >= 2:
                    write_state(path, history[-2])

            elif event.get("type") == "window-closed":
                addr = event.get("window", {}).get("address")
                if not addr:
                    continue
                if not ADDR_REGEX.fullmatch(addr):
                    continue
                history = deque([a for a in history if a != addr], maxlen=20)
                if len(history) >= 2:
                    write_state(path, history[-2])
                elif history:
                    write_state(path, history[0])
                else:
                    remove_state(path)
    finally:
        cleanup()

def main() -> int:
    if "--switch" in sys.argv:
        return switch()
    daemon()


if __name__ == "__main__":
    sys.exit(main())
