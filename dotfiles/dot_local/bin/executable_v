#!/usr/bin/env zsh
# v: open Neovim with system profile sourced
# Usage: v [ARGS...]
export NVIM_APPNAME=
. /etc/profile
SOCKET="/tmp/nvim.sock"

_is_image() {
  local ext="${1:e:l}"
  [[ "$ext" == png || "$ext" == jpg || "$ext" == jpeg || "$ext" == gif || "$ext" == webp || "$ext" == avif ]]
}

IMAGES=()
FILES=()
for arg in "$@"; do
  if _is_image "$arg"; then IMAGES+=("$arg"); else FILES+=("$arg"); fi
done

# Show images inline in terminal via kitty icat
if [ "${#IMAGES[@]}" -gt 0 ]; then
  for img in "${IMAGES[@]}"; do
    kitty +kitten icat "$img"
  done
fi

# If only images were given, we're done — no nvim needed
if [ "${#FILES[@]}" -eq 0 ] && [ "${#IMAGES[@]}" -gt 0 ]; then
  exit 0
fi

if ! command -v nvr >/dev/null 2>&1; then
  echo "error: nvr is required for remote attachment; reinstall neovim-remote" >&2
  exit 127
fi

# Open non-image files in existing nvim instance
if [ -S "$SOCKET" ] && nc -zU "$SOCKET" >/dev/null 2>&1; then
  if [ "${#FILES[@]}" -gt 0 ]; then
    nvr --servername "$SOCKET" --remote-silent "${FILES[@]}"
  fi
  hyprctl dispatch focuswindow "class:nwim" >/dev/null
  echo "↗  nvim (attached)"
else
  rm -f "$SOCKET"
  exec nvim --listen "$SOCKET" "${FILES[@]}"
fi
