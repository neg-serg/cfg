{#- Shared host-definition proxy for .sls states.
    Imports from host_config.jinja + system.yaml directly (no _macros_common).
    Jinja2 {% from %} imports do NOT re-export — only {% set %} creates module exports.
    Usage: {% from '_imports.jinja' import host, user, home %}
-#}
{%- import 'host_config.jinja' as _hc with context -%}
{%- set host = _hc.host -%}
{%- set user = host.user -%}
{%- set home = host.home -%}
{%- set pkg_list = host.pkg_list -%}
{%- import_yaml 'data/system.yaml' as _system -%}
{%- set retry_attempts = _system.timeouts.retry_attempts -%}
{%- set retry_interval = _system.timeouts.retry_interval -%}
{%- set ver_dir = host.ver_dir -%}
{%- set sys_ver_dir = host.sys_ver_dir -%}
{%- set download_cache = host.download_cache -%}
{%- set healthcheck_timeout = _system.timeouts.healthcheck_timeout -%}
{%- set sudo_timeout_minutes = _system.timeouts.sudo_timeout_minutes -%}
{%- set ollama_pull_timeout = _system.timeouts.ollama_pull_timeout -%}
