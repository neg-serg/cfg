{# Shared constants for Salt templates.
   All macros have been migrated to Python modules in states/_modules/.
   See: salt['host.feature_enabled']('mpd'), salt['container.deploy'](...), etc.
   
   Remaining: only data YAML imports and constant declarations.
   No {% macro %} definitions — all business logic is in Python.
#}
{%- import 'host_config.jinja' as _hc with context -%}
{%- set host = _hc.host -%}
{%- set user = host.user -%}
{%- set home = host.home -%}
{%- set pkg_list = host.pkg_list -%}
{%- set retry_attempts = 3 -%}
{%- set retry_interval = 10 -%}
{%- set ver_dir = home ~ '/.cache/salt-versions' -%}
{%- set sys_ver_dir = '/var/cache/salt/versions' -%}
{%- set download_cache = '/var/cache/salt/downloads' -%}
{%- set healthcheck_timeout = 30 -%}
{%- set sudo_timeout_minutes = -1 -%}
{%- set ollama_pull_timeout = 14400 -%}
{%- set registry = _hc.registry if _hc.registry is defined else {} -%}
