{# Config-editing macros: config_file_edit #}

{% from '_macros_common.jinja' import user as _user, home as _home, retry_attempts as _retry_attempts, retry_interval as _retry_interval %}

{# Wrap a config-file edit command with idempotency guard and optional retry.
   cmd: shell command to apply the edit (sed, btrfs property set, printf >>, etc.).
   unless: explicit guard command (overrides auto-guard). Auto-guard: if check_pattern
   and check_file are set, generates: grep -q '<check_pattern>' <check_file>.
   onlyif: conditional execution guard (state skipped when onlyif fails).
   retry: True to add network retry (3 attempts, 10s interval) — use for commands
   that touch the network (e.g. pacman -Sy after config edit).
   Usage: {{ config_file_edit('limine_timeout', cmd="sed -i 's/^timeout:.*/timeout: 1/' /boot/limine.conf", check_pattern='^timeout: 1$', check_file='/boot/limine.conf') }}
          {{ config_file_edit('multilib_repo', cmd="printf ... >> /etc/pacman.conf && pacman -Sy", check_pattern='^\[multilib\]', check_file='/etc/pacman.conf', retry=True) }}
#}
{%- macro config_file_edit(name, cmd, unless=None, check_pattern=None, check_file=None, onlyif=None, require=None, retry=False, shell=None) -%}
{%- set _guard = unless if unless is not none else ("grep -q '" ~ check_pattern ~ "' " ~ check_file if check_pattern and check_file else None) -%}
{{ name }}:
  cmd.run:
    - name: |
        {{ cmd | trim | indent(8) }}
{%- if shell %}
    - shell: {{ shell }}
{%- endif %}
{%- if _guard %}
    - unless: |
        {{ _guard | trim | indent(8) }}
{%- endif %}
{%- if onlyif %}
    - onlyif: |
        {{ onlyif | trim | indent(8) }}
{%- endif %}
{%- if retry %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endif %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# File-management macros for user config files, secret files, and desktop entries #}

{# Create a managed file with user ownership and optional replace=False.
   Usage: {{ user_config_file('my_config', '/path/to/file', contents='config data', mode='0644', replace=False, require=['file: config_dir']) }}
#}
{%- macro user_config_file(name, path, contents, user=_user, mode='0644', replace=True, require=None, group=None, context=None, template='jinja', source=None) -%}
{% if group is none %}{% set group = user %}{% endif %}
{{ name }}:
  file.managed:
    - name: {{ path }}
    - user: {{ user }}
    - group: {{ group }}
    - mode: '{{ mode }}'
    {% if not replace %}
    - replace: False
    {% endif %}
    {%- if source %}
    - source: {{ source }}
    {%- if template %}
    - template: {{ template }}
    {%- endif %}
    {%- if context %}
    - context:
      {{ context | tojson | indent(8) }}
    {%- endif %}
    {%- else %}
    - contents: |
{{ contents | trim | indent(8, first=True) }}
    {%- endif %}
    {%- if require %}
    - require:
    {%- for req in require %}
      - {{ req }}
    {%- endfor %}
    {% endif %}
{%- endmacro -%}

{# Shortcut for secret files (0600 mode, replace=False).
   Usage: {{ secret_file('my_secret', '/path/to/secret', contents='secret data', require=['user: my_user']) }}
#}
{%- macro secret_file(name, path, contents, user=_user, require=None) -%}
{{ user_config_file(name, path, contents, user=user, mode='0600', replace=False, require=require) }}
{%- endmacro -%}

{# Create desktop entry (.desktop) files with standard format.
   Usage: {{ desktop_entry('vr_session', '/usr/share/xsessions/vr.desktop', 'Xorg VR', 'VR session', 'startx', 'i3') }}
#}
{%- macro desktop_entry(name, path, entry_name, comment, exec, desktop_names, type='XSession', user='root', group='root', mode='0644') -%}
{{ name }}:
  file.managed:
    - name: {{ path }}
    - user: {{ user }}
    - group: {{ group }}
    - mode: '{{ mode }}'
    - contents: |
        [Desktop Entry]
        Name={{ entry_name }}
        Comment={{ comment }}
        Exec={{ exec }}
        Type={{ type }}
        DesktopNames={{ desktop_names }}
{%- endmacro -%}

{# Generate multiple config files in a loop.
   Usage: {{ config_files_loop('kde', '/home/user/.config', {'kdeglobals': '...', 'plasmarc': '...'}, user='user', mode='0644') }}
#}
{%- macro config_files_loop(base_name, config_dir, files, user=_user, mode='0644', replace=False, require_base=None) -%}
{%- for filename, contents in files.items() %}
{{ base_name }}_{{ filename }}:
  file.managed:
    - name: {{ config_dir }}/{{ filename }}
    - user: {{ user }}
    - group: {{ user }}
    - mode: '{{ mode }}'
    {%- if not replace %}
    - replace: False
    {%- endif %}
    - contents: |
{{ contents | trim | indent(8, first=True) }}
    {%- if require_base %}
    - require:
      - file: {{ require_base }}
    {%- endif %}
{%- endfor %}
{%- endmacro -%}
