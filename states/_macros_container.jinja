{# Container-service supervisor macros: container_service, _tilde_expand, _cs_fail #}

{% from '_macros_common.jinja' import user as _user, home as _home, host, retry_attempts as _retry_attempts, retry_interval as _retry_interval %}
{% from '_macros_service.jinja' import service_with_healthcheck, env_block %}
{% import_yaml 'data/service_catalog.yaml' as catalog %}
{% import_yaml 'data/container_images.yaml' as image_registry %}

{# env_block imported from _macros_service.jinja — was previously duplicated here due to Jinja underscore-prefix restriction #}

{# Tilde-expand a bind-mount host path against the caller's home directory.
   Used by container_service() to render absolute host paths in Quadlet Volume= lines.
   '~' alone → home; '~/foo' → home/foo; anything else passes through unchanged.
#}
{%- macro _tilde_expand(raw_path, home_value) -%}
{%- if raw_path == '~' -%}
{{ home_value }}
{%- elif raw_path is string and raw_path.startswith('~/') -%}
{{ home_value }}/{{ raw_path[2:] }}
{%- else -%}
{{ raw_path }}
{%- endif -%}
{%- endmacro -%}

{# Containerized-service supervisor — deploys a Podman Quadlet .container unit,
   pulls the digest-pinned image (or skips pull for localhost images),
   reloads systemd, enables/starts the unit, and delegates the catalog healthcheck.

   Arguments:
     name            - state ID prefix AND Quadlet unit basename; must match a
                       top-level key in service_catalog.yaml
     catalog_entry   - dict from service_catalog.yaml[name]; MUST include
                       container_image key
     image_registry  - parsed container_images.yaml map; the macro reads
                       image_registry[catalog_entry.container_image]
     user_scope      - True for rootless user-scoped Quadlet (must match
                       catalog_entry.scope == 'user')
     requires        - extra state requisites appended to the pull state
     watch           - extra state requisites appended to the running state
     quadlet_unit_name - override the Quadlet file basename (default: name)

   Emitted states:
     {name}_container, {name}_image_pull (skipped for localhost),
     {name}_daemon_reload,
     {name}_enabled (skipped if manual_start), {name}_reset_failed (skipped
     if manual_start), {name}_running (skipped if manual_start),
     {name}_healthcheck (skipped if manual_start).

   Render-time preconditions (fail loudly if violated):
     1. catalog_entry.container_image resolves to a key in image_registry
     2. image_registry[...].digest matches sha256:<64 hex> (remote images)
        OR registry == 'localhost' (local images, digest may be null)
     3. user_scope agreement with catalog_entry.scope
     4. gpu == 'amdgpu' implies scope == 'system'

    Usage:
      {{ container_service('ollama', catalog.ollama, image_registry,
                           requires=['file: ollama_models_dir', 'mount: mount_one']) }}
      {{ container_service('telethon_bridge', catalog.telethon_bridge, image_registry,
                           user_scope=True,
                           requires=['cmd: install_python_telethon']) }}

    Naming convention (quadlet_unit_name):
      Services that previously had native systemd units use quadlet_unit_name
      with '-container' suffix (e.g., 'loki-container') to avoid shadowing
      the removed native unit.  New services use the catalog name unchanged
      (e.g., 'ollama' → ollama.container, ollama.service).
#}
{%- macro _cs_fail(name, error_key, message) -%}
container_service_PRECONDITION_FAILED_{{ name }}_{{ error_key }}:
  test.fail_without_changes:
    - name: 'container_service({{ name }}): {{ message }}'
    - failhard: True
{%- endmacro -%}

{%- macro container_service(name, catalog_entry, image_registry, user_scope=False, requires=None, watch=None, quadlet_unit_name=None) -%}
{%- set _quadlet_name = quadlet_unit_name if quadlet_unit_name is not none else name -%}
{#- Precondition: image_registry lookup -#}
{%- set _image_key = catalog_entry.get('container_image') -%}
{%- if _image_key is none or _image_key not in image_registry -%}
{{ _cs_fail(name, 'image_key_missing', 'container_image "' ~ (_image_key or 'null') ~ '" not found in container_images.yaml') }}
{%- else -%}
{%- set _img = image_registry[_image_key] -%}
{%- set _digest = _img.get('digest') -%}
{%- set _registry = _img.get('registry') -%}
{%- set _is_localhost = (_registry == 'localhost') -%}
{%- set _catalog_scope = catalog_entry.get('scope') -%}
{%- set _gpu = catalog_entry.get('gpu', 'none') -%}
{%- set _digest_ok = (_is_localhost and _digest is none) or (_digest is string and _digest.startswith('sha256:') and _digest | length == 71) -%}
{%- set _scope_ok = (user_scope and _catalog_scope == 'user') or ((not user_scope) and _catalog_scope == 'system') -%}
{%- set _gpu_ok = not (_gpu == 'amdgpu' and user_scope) -%}
{%- if not _digest_ok -%}
{{ _cs_fail(name, 'bad_digest', 'image digest "' ~ (_digest or 'null') ~ '" does not match sha256:<64 hex> (or registry is not localhost)') }}
{%- elif not _scope_ok -%}
{{ _cs_fail(name, 'scope_mismatch', 'user_scope=' ~ user_scope ~ ' but catalog scope is "' ~ (_catalog_scope or 'null') ~ '"') }}
{%- elif not _gpu_ok -%}
{{ _cs_fail(name, 'gpu_scope_violation', 'gpu=amdgpu requires system scope') }}
{%- else -%}
{#- All preconditions passed: resolve paths and image reference -#}
{%- if _is_localhost -%}
{%- set _full_image = 'localhost/' ~ _img.image -%}
{%- else -%}
{%- set _full_image = _img.registry ~ '/' ~ _img.image ~ '@' ~ _digest -%}
{%- endif -%}
{%- set _manual_start = catalog_entry.get('manual_start', False) -%}
{#- Quadlet file location depends on scope -#}
{%- if user_scope -%}
{%- set _quadlet_path = _home ~ '/.config/containers/systemd/' ~ _quadlet_name ~ '.container' -%}
{%- set _quadlet_source = 'salt://units/user/' ~ _quadlet_name ~ '.container' -%}
{%- else -%}
{%- set _quadlet_path = '/etc/containers/systemd/' ~ _quadlet_name ~ '.container' -%}
{%- set _quadlet_source = 'salt://units/' ~ _quadlet_name ~ '.container' -%}
{%- endif -%}
{#- Pre-compute bind-mount list with tilde expansion -#}
{%- set _expanded_mounts = [] -%}
{%- for bm in catalog_entry.get('bind_mounts', []) -%}
{%- set _host = _tilde_expand(bm.host, _home) | trim -%}
{%- do _expanded_mounts.append({'host': _host, 'container': bm.container, 'mode': bm.mode}) -%}
{%- endfor -%}

# container_service({{ name }}): Quadlet unit file ({{ 'user' if user_scope else 'system' }} scope)
{{ name }}_container:
  file.managed:
    - name: {{ _quadlet_path }}
    - source: {{ _quadlet_source }}
    - template: jinja
    - mode: '0644'
    - makedirs: True
{%- if user_scope %}
    - user: {{ _user }}
    - group: {{ _user }}
{%- endif %}
    - context:
        catalog_entry: {{ catalog_entry | tojson }}
        image: {{ _full_image }}
        expanded_mounts: {{ _expanded_mounts | tojson }}
        user_scope: {{ user_scope | tojson }}

{#- Image pull: skip for localhost (images must be built manually) -#}
{% if not _is_localhost %}
# container_service({{ name }}): digest-pinned image pull (idempotent via `podman image exists`)
{{ name }}_image_pull:
  cmd.run:
    - name: podman pull {{ _full_image }}
    - unless: podman image exists {{ _full_image }}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{{ env_block() }}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{% endif %}

# container_service({{ name }}): daemon-reload so Quadlet regenerates the systemd unit
{{ name }}_daemon_reload:
  cmd.run:
    - name: systemctl {% if user_scope %}--user {% endif %}daemon-reload
{%- if user_scope %}
    - onlyif: systemctl --user show-environment >/dev/null 2>&1
{%- else %}
    - onlyif: test -e /run/systemd/system || test -e /etc/systemd/system
{%- endif %}
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{{ env_block() }}
{%- endif %}
    - onchanges:
      - file: {{ name }}_container

{%- if not _manual_start %}

# container_service({{ name }}): enable + reset_failed + running + healthcheck
{{ name }}_enabled:
  cmd.run:
    - name: systemctl {% if user_scope %}--user {% endif %}is-enabled {{ _quadlet_name }}.service >/dev/null 2>&1 || systemctl {% if user_scope %}--user {% endif %}enable {{ _quadlet_name }}.service
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{{ env_block() }}
{%- endif %}
    - unless: systemctl {% if user_scope %}--user {% endif %}is-enabled {{ _quadlet_name }}.service >/dev/null 2>&1
    - require:
{%- if _is_localhost %}
      - cmd: {{ name }}_daemon_reload
{%- else %}
      - cmd: {{ name }}_image_pull
      - cmd: {{ name }}_daemon_reload
{%- endif %}

{{ name }}_reset_failed:
  cmd.run:
    - name: systemctl {% if user_scope %}--user {% endif %}reset-failed {{ _quadlet_name }} 2>/dev/null; true
    - onlyif: systemctl {% if user_scope %}--user {% endif %}is-failed {{ _quadlet_name }}
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{{ env_block() }}
{%- endif %}
    - require:
      - cmd: {{ name }}_enabled

{{ name }}_running:
{%- if user_scope %}
  cmd.run:
    - name: systemctl --user is-active {{ _quadlet_name }}.service >/dev/null 2>&1 || systemctl --user start {{ _quadlet_name }}.service
    - runas: {{ _user }}
    - env:
{{ env_block() }}
    - unless: systemctl --user is-active {{ _quadlet_name }}.service >/dev/null 2>&1
{%- else %}
  service.running:
    - name: {{ _quadlet_name }}
{%- endif %}
    - watch:
      - file: {{ name }}_container
{%- for w in (watch or []) %}
      - {{ w }}
{%- endfor %}
    - require:
      - cmd: {{ name }}_enabled
      - cmd: {{ name }}_reset_failed
{%- endif %}

{#- Post-start healthcheck via service_with_healthcheck (skipped for manual_start). -#}
{%- if not _manual_start %}

{{ service_with_healthcheck(name ~ '_healthcheck', _quadlet_name, catalog={_quadlet_name: catalog_entry}, requires=['service: ' ~ name ~ '_running'] if not user_scope else ['cmd: ' ~ name ~ '_running'], user_scope=user_scope, user=_user) }}
{%- endif %}
{%- endif %}{# close "all preconditions passed" #}
{%- endif %}{# close "image key found in registry" #}
{%- endmacro -%}
