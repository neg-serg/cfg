{# IPv6 tunnel deployment macro.
   Encapsulates: nftables firewall file + apply, optional sysctl config + apply,
   systemd unit deployment, daemon-reload, enable, start, and optional healthcheck.

   Parameters:
     name             — state ID prefix (e.g. 'tun6to4', 'he_tunnel')
     interface        — tunnel device name (e.g. 'tun6to4', 'he-ipv6')
     service_name     — systemd unit name (e.g. 'tun6to4', 'he-tunnel')
     service_template — salt:// path to unit template (.service.j2)
     service_context  — dict of template variables for the unit template
     firewall_table   — nftables table name AND config file basename
     firewall_rules   — inline nftables rules content (empty to skip firewall)
     sysctl_config    — inline sysctl.conf content (empty to skip sysctl)
     enable_healthcheck — if True, poll for IPv6 address on the interface

   Usage:
     {% from '_macros_ipv6_tunnel.jinja' import ipv6_tunnel with context %}
     {{ ipv6_tunnel(name='tun6to4', interface='tun6to4', ...) }}
#}

{% from '_macros_service.jinja' import service_with_unit %}

{%- macro ipv6_tunnel(name,
                      interface,
                      service_name,
                      service_template,
                      service_context={},
                      firewall_table='ipv6-tunnel',
                      firewall_rules='',
                      sysctl_config='',
                      enable_healthcheck=False) -%}
{%- set _fw_path = host.nftables_dir ~ firewall_table ~ '.conf' -%}
{%- set _has_firewall = firewall_rules | length > 0 -%}
{%- set _has_sysctl = sysctl_config | length > 0 -%}
{%- set _svc_requires = [] -%}
{%- set _svc_watch = [] -%}
{%- if _has_firewall -%}
{%- set _ = _svc_requires.append('cmd: ' ~ name ~ '_firewall_apply') %}

{{ name }}_firewall:
  file.managed:
    - name: {{ _fw_path }}
    - mode: '0644'
    - makedirs: True
    - contents: |
{{ firewall_rules | trim | indent(8, first=True) }}

{{ name }}_firewall_apply:
  cmd.run:
    - name: |
        set -euo pipefail
        if command -v nft &>/dev/null; then
          nft -f {{ _fw_path }} 2>/dev/null || { nft delete table inet {{ firewall_table }} 2>/dev/null || true; nft -f {{ _fw_path }}; }
        elif command -v ip6tables &>/dev/null; then
          ip6tables -I INPUT -i {{ interface }} -p icmpv6 -j ACCEPT 2>/dev/null || true
          ip6tables -I FORWARD -i {{ interface }} -p icmpv6 -j ACCEPT 2>/dev/null || true
          ip6tables -I INPUT -i {{ interface }} -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true
          ip6tables -I FORWARD -i {{ interface }} -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true
        fi
    - shell: /bin/bash
    - onchanges:
      - file: {{ name }}_firewall
{%- endif -%}
{%- if _has_sysctl -%}
{%- set _ = _svc_watch.append('file: ' ~ name ~ '_sysctl') %}

{{ name }}_sysctl:
  file.managed:
    - name: {{ host.sysctl_dir }}99-{{ name }}.conf
    - mode: '0644'
    - contents: |
{{ sysctl_config | trim | indent(8, first=True) }}

{{ name }}_sysctl_apply:
  cmd.run:
    - name: sysctl --system
    - onchanges:
      - file: {{ name }}_sysctl
{%- endif %}

{{ service_with_unit(service_name, service_template, enabled=True, running=True, template='jinja', context=service_context, requires=_svc_requires, watch=_svc_watch) }}
{%- if enable_healthcheck %}

{{ name }}_healthcheck:
  cmd.run:
    - name: |
        set -euo pipefail
        for i in $(seq 1 30); do
          ip -6 addr show {{ interface }} 2>/dev/null | grep -q 'inet6' && exit 0
          sleep 1
        done
        echo "Tunnel {{ name }}: no IPv6 address after 30s" >&2
        exit 1
    - shell: /bin/bash
    - unless: ip -6 addr show {{ interface }} 2>/dev/null | grep -q 'inet6'
    - require:
      - service: {{ service_name }}_enabled
{%- endif -%}
{%- endmacro -%}
