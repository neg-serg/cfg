# RKN Domains Fetcher Configuration
# Managed by Salt

rkn_domains_fetcher:
  enabled: true
  
  settings:
    update_interval_hours: {{ salt['pillar.get']('rkn_domains_fetcher:settings:update_interval_hours', 24) }}
    max_domains: {{ salt['pillar.get']('rkn_domains_fetcher:settings:max_domains', 50000) }}
    domain_validation: {{ salt['pillar.get']('rkn_domains_fetcher:settings:domain_validation', true) }}
    
    # Autocorrection settings
    autocorrection:
      enabled: true
      health_check_url: "https://httpbin.org/ip"
      health_check_timeout: 10
      max_consecutive_failures: 3
      fallback_to_cache: true
      cache_max_age_days: 7
      emergency_list_enabled: true
    
    # Monitoring
    monitoring:
      enabled: true
      check_interval_minutes: 60
      alert_on_stale_days: 2
      notify_on_failure: true
  
  sources:
    primary: "{{ salt['pillar.get']('rkn_domains_fetcher:sources:primary', 'https://raw.githubusercontent.com/EikeiDev/domains/main/domains.lst') }}"
    
    backups:
      - "{{ salt['pillar.get']('rkn_domains_fetcher:sources:backups:0', 'https://raw.githubusercontent.com/zapret-info/z-i/master/dump.csv') }}"
      - "{{ salt['pillar.get']('rkn_domains_fetcher:sources:backups:1', 'https://raw.githubusercontent.com/antifilter/filterlist/master/antifilter.list') }}"
    
    # Local fallback sources (if internet is down)
    local_fallbacks:
      - "/var/cache/rkn-domains/latest.txt"
      - "{{ user.home }}/.cache/rkn-domains/backup.txt"
  
  integration:
    vpn_split_router:
      enabled: {{ salt['pillar.get']('rkn_domains_fetcher:integration:vpn_split_router:enabled', true) }}
      auto_mark_vpn: {{ salt['pillar.get']('rkn_domains_fetcher:integration:vpn_split_router:auto_mark_vpn', true) }}
      update_on_change: true
    
    singbox:
      enabled: {{ salt['pillar.get']('rkn_domains_fetcher:integration:singbox:enabled', true) }}
      config_path: "{{ salt['pillar.get']('rkn_domains_fetcher:integration:singbox:config_path', '~/.config/sing-box-tun/config-no-auto-route.json') }}"
      max_domains_per_rule: 1000
    
    # DNS-based integration (alternative)
    dns:
      enabled: {{ salt['pillar.get']('rkn_domains_fetcher:integration:dns:enabled', false) }}
      dnsmasq_config: "/etc/dnsmasq.d/rkn-blocked.conf"
      block_ip: "0.0.0.0"
  
  # Emergency configuration
  emergency:
    enabled: true
    essential_domains:
      - "twitter.com"
      - "instagram.com"
      - "facebook.com"
      - "tiktok.com"
      - "whatsapp.com"
      - "discord.com"
      - "telegram.org"
      - "youtube.com"
      - "twitch.tv"
      - "reddit.com"
      - "claude.ai"
      - "openai.com"
      - "chatgpt.com"
      - "anthropic.com"
    create_if_missing: true
    max_age_hours: 168  # 7 days
  
  # Logging and debugging
  logging:
    level: "{{ salt['pillar.get']('rkn_domains_fetcher:logging:level', 'INFO') }}"
    file: "{{ user.home }}/.local/state/rkn-domains-fetcher/rkn-domains-fetcher.log"
    max_size_mb: 10
    backup_count: 3
  
  # Systemd service configuration
  systemd:
    user_service: true
    timer_enabled: true
    timer_schedule: "daily"
    randomized_delay_sec: 3600
    retry_on_failure: true
    max_retries: 3
    retry_delay_sec: 300