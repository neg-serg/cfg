{#
    Per-host configuration map.
    
    Usage in any .sls file:
      {% from 'host_config.jinja' import host %}
      {% if host.is_laptop %}
        ...laptop-specific states...
      {% endif %}
    
    Data lives in states/data/hosts.yaml — defaults + host overrides + aliases.
    Add a new machine by editing that YAML file; values fall back to defaults.
    
    ── Merge contract (must match host_model.py recursive_merge) ──────────
    * Dicts merge recursively (override keys added, existing keys overridden)
    * Non-dict scalars (str, int, bool, None) replace base values entirely
    * None, False, 0, "" are valid override values (not skipped)
    * Empty dict in override is a no-op (does not clobber base dict)
    * Lists are replaced wholesale (not concatenated)
    * Base dict must never be mutated by merge (pure function)
    * New keys can be introduced at any nesting level
    
    Test coverage: tests/test_host_model.py (50 tests, merge section)
    Python implementation: scripts/host_model.py recursive_merge()
    Jinja implementation: salt['slsutil.merge'](..., strategy='recurse')
#}

{% import_yaml 'data/hosts.yaml' as hosts_data %}
{% set defaults = hosts_data.defaults %}
{% set hosts = hosts_data.get('hosts', {}) %}
{% set aliases = hosts_data.get('aliases', {}) %}
{% import_yaml 'data/feature_matrix.yaml' as feature_matrix %}
{% import_yaml 'data/feature_registry.yaml' as registry %}

{# Inject feature-matrix scenarios as synthetic hosts (lint/render only). #}
{% for scenario in feature_matrix or [] %}
{%- if scenario.overrides is mapping %}
{%- set overrides = scenario.overrides %}
{%- if 'hostname' not in overrides %}
{%-   do overrides.update({'hostname': scenario.name}) %}
{%- endif %}
{%-   do hosts.update({scenario.name: overrides}) %}
{%- endif %}
{% endfor %}

{# Hostname aliases for migration (e.g. first run before rename) #}
{% set current_host = aliases.get(grains['host'], grains['host']) %}

{# Build merged host config: host-specific values override defaults (recursive deep merge) #}
{% set host = salt['slsutil.merge'](defaults, hosts.get(current_host, {}), strategy='recurse') %}
{# Derived fields (depend on merged values, so computed after merge) #}
{% if not host.get('home') %}
{%   do host.update({'home': '/home/' ~ host.user}) %}
{% endif %}
{% do host.update({'runtime_dir': '/run/user/' ~ host.uid|string}) %}
{% do host.update({'pkg_list': '/var/cache/salt/pacman_installed.txt'}) %}
{% set project_dir = salt['config.get']('project_dir', host.home ~ '/src/cfg') %}
{% do host.update({'project_dir': project_dir}) %}
{% do host.update({'ver_dir': host.home ~ '/.cache/salt-versions'}) %}
{% do host.update({'sys_ver_dir': '/var/cache/salt/versions'}) %}
{% do host.update({'download_cache': '/var/cache/salt/downloads'}) %}
{% do host.update({'gopass_dir': host.home ~ '/.local/share/pass'}) %}
{% do host.update({'gnupg_dir': host.home ~ '/.local/share/gnupg'}) %}
