#!/usr/bin/env bash
set -euo pipefail

log() { echo "[fmod-link] $(date +%H:%M:%S) $*"; }

RME_NODE={{ rme_node }}

for i in $(seq 1 30); do
    if pw-cli list-objects Node | grep -q '"fmod_sink"'; then
        log "fmod_sink found"
        break
    fi
    sleep 0.5
done

for i in $(seq 1 30); do
    if pw-cli list-objects Node | grep -q "$RME_NODE"; then
        log "RME output found"
        break
    fi
    sleep 0.5
done

pw-link "fmod_sink:monitor_FL" "$RME_NODE:playback_AUX0" && log "Linked FL"
pw-link "fmod_sink:monitor_FR" "$RME_NODE:playback_AUX1" && log "Linked FR"

pactl set-default-sink fmod_sink && log "Default sink set"
