#!/usr/bin/env bash
set -euo pipefail

NULL_SINK="game_output"
TARGET_LEFT=0
TARGET_RIGHT=1
RME_NICK="RME AIO Pro"

find_rme_sink() {
    pw-cli list-objects Node 2>/dev/null | awk -v nick="$RME_NICK" '
        /^id/ { node = "" }
        /node.name/ && /alsa_output/ { node = $3; gsub("\"", "", node) }
        index($0, "node.nick = \"" nick "\"") && node != "" { print node; exit }
    '
}

RME_OUT=""
for i in $(seq 1 30); do
    RME_OUT="$(find_rme_sink)"
    [[ -n "$RME_OUT" ]] && break
    sleep 0.5
done
[[ -n "$RME_OUT" ]] || { echo "game-audio-bridge: RME sink not found" >&2; exit 1; }

# Wait for game_output null-sink to appear (created by pipewire.conf.d)
for i in $(seq 1 10); do
    if pactl list short sinks 2>/dev/null | grep -q "$NULL_SINK"; then
        break
    fi
    sleep 0.5
done

# Link game_output -> RME pro-output
pw-link "${NULL_SINK}:monitor_FL" "${RME_OUT}:playback_AUX${TARGET_LEFT}" 2>/dev/null || true
pw-link "${NULL_SINK}:monitor_FR" "${RME_OUT}:playback_AUX${TARGET_RIGHT}" 2>/dev/null || true

# Set game_output as default for PulseAudio clients (FMOD-friendly 16-bit stereo)
pactl set-default-sink "$NULL_SINK" 2>/dev/null || true
