#!/usr/bin/env python3
"""
Set proxy configuration for Zen Browser by writing to user.js in the profile.
Usage: set-zen-proxy <mode> where mode is: direct, telegram, debug, system_vpn
"""

import os
import sys
import json
import argparse
from pathlib import Path
import configparser

PROFILES_INI = Path.home() / ".config/zen/profiles.ini"


def resolve_profile_path() -> Path:
    """Resolve the active Zen release profile from profiles.ini."""
    if not PROFILES_INI.exists():
        raise FileNotFoundError(f"Zen profiles.ini not found: {PROFILES_INI}")

    parser = configparser.RawConfigParser()
    parser.read(PROFILES_INI)

    install_section = next((name for name in parser.sections() if name.startswith("Install")), None)
    if install_section and parser.has_option(install_section, "Default"):
        rel_path = parser.get(install_section, "Default")
        return PROFILES_INI.parent / rel_path

    for section in parser.sections():
        if parser.has_option(section, "Name") and parser.get(section, "Name") == "Default (release)":
            rel_path = parser.get(section, "Path")
            return PROFILES_INI.parent / rel_path

    raise FileNotFoundError("Could not resolve Zen release profile from profiles.ini")


PROFILE_PATH = resolve_profile_path()
USER_JS = PROFILE_PATH / "user.js"

# Proxy mode definitions
PROXY_MODES = {
    "direct": {
        "network.proxy.type": 0,
        "network.proxy.socks": "",
        "network.proxy.socks_port": 0,
        "network.proxy.socks_version": 5,
        "network.proxy.allow_hijacking_localhost": False,
        "network.proxy.no_proxies_on": "",
        "network.proxy.socks_remote_dns": False,
    },
    "telegram": {
        "network.proxy.type": 1,
        "network.proxy.socks": "localhost",
        "network.proxy.socks_port": 10808,
        "network.proxy.socks_version": 5,
        "network.proxy.allow_hijacking_localhost": True,
        "network.proxy.no_proxies_on": "localhost, 127.0.0.1, 192.168.2.0/24",
        "network.proxy.socks_remote_dns": True,
    },
    "debug": {
        "network.proxy.type": 1,
        "network.proxy.socks": "localhost",
        "network.proxy.socks_port": 10810,
        "network.proxy.socks_version": 5,
        "network.proxy.allow_hijacking_localhost": True,
        "network.proxy.no_proxies_on": "localhost, 127.0.0.1, 192.168.2.0/24",
        "network.proxy.socks_remote_dns": True,
    },
    "system_vpn": {
        "network.proxy.type": 1,
        "network.proxy.socks": "localhost",
        "network.proxy.socks_port": 10808,
        "network.proxy.socks_version": 5,
        "network.proxy.allow_hijacking_localhost": True,
        "network.proxy.no_proxies_on": "localhost, 127.0.0.1, 192.168.2.0/24",
        "network.proxy.socks_remote_dns": True,
    },
}

def read_existing_userjs():
    """Read existing user.js lines, preserving non‑proxy preferences."""
    if not USER_JS.exists():
        return []
    with open(USER_JS, 'r') as f:
        lines = f.readlines()
    # Remove lines that start with user_pref("network.proxy.
    return [line for line in lines if not line.strip().startswith('user_pref("network.proxy.')]

def write_userjs(mode_key):
    """Write user.js with proxy settings for the given mode."""
    if mode_key not in PROXY_MODES:
        print(f"Unknown mode: {mode_key}", file=sys.stderr)
        return False
    
    mode = PROXY_MODES[mode_key]
    existing = read_existing_userjs()
    
    with open(USER_JS, 'w') as f:
        f.write("// Proxy settings generated by set-zen-proxy\n")
        f.write("// Mode: " + mode_key + "\n")
        for line in existing:
            f.write(line)
        # Ensure a newline before our settings
        if existing and not existing[-1].endswith('\n'):
            f.write('\n')
        for pref, value in mode.items():
            if isinstance(value, str):
                f.write(f'user_pref("{pref}", "{value}");\n')
            elif isinstance(value, bool):
                f.write(f'user_pref("{pref}", {"true" if value else "false"});\n')
            else:
                f.write(f'user_pref("{pref}", {value});\n')
    
    print(f"Proxy set to {mode_key}")
    print(f"  SOCKS: {mode.get('network.proxy.socks', '')}:{mode.get('network.proxy.socks_port', 0)}")
    print(f"  Note: Restart Zen Browser for changes to take effect.")
    return True

def main():
    parser = argparse.ArgumentParser(description="Set Zen Browser proxy mode")
    parser.add_argument("mode", choices=list(PROXY_MODES.keys()), help="Proxy mode")
    parser.add_argument("--list", action="store_true", help="List available modes")
    args = parser.parse_args()
    
    if args.list:
        for key, config in PROXY_MODES.items():
            print(f"{key}: type={config['network.proxy.type']}, "
                  f"socks={config['network.proxy.socks']}:{config['network.proxy.socks_port']}")
        return 0
    
    if not PROFILE_PATH.exists():
        print(f"Profile directory not found: {PROFILE_PATH}", file=sys.stderr)
        return 1
    
    success = write_userjs(args.mode)
    return 0 if success else 1

if __name__ == "__main__":
    sys.exit(main())
