[Unit]
Description=Apply critical Salt states at boot (group/core)
Documentation=https://docs.saltproject.io/
After=local-fs.target network.target
Wants=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
TimeoutStartSec=180
ExecCondition=/usr/bin/test -f {{ project_dir }}/.venv/bin/salt-call
ExecStart={{ project_dir }}/scripts/salt-boot-apply.sh {{ project_dir }}
WorkingDirectory={{ project_dir }}
StandardOutput=journal+console
StandardError=journal+console

# Safety: no restart loop. If it fails, it stays failed.
# Monitoring (salt-monitor) can detect and alert.
Restart=no

[Install]
WantedBy=multi-user.target
